{
  "name": "@lekterminal/claude-deck",
  "version": "0.1.0",
  "description": "Local dashboard for Claude Code sessions across projects — live status, transcripts, resume, AI summaries. 127.0.0.1 only.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "claude-deck": "bin/claude-deck.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts/statusline-bridge.mjs",
    "docs/screenshots"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LekTerMiNaL/claude-deck.git"
  },
  "homepage": "https://github.com/LekTerMiNaL/claude-deck#readme",
  "bugs": "https://github.com/LekTerMiNaL/claude-deck/issues",
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "sessions",
    "local-first",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,magenta \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "prepare": "npm run build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "qa:shots": "tsx scripts/qa-shots.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
